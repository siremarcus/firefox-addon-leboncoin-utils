{
  "manifest_version": 2,
  "name": "Leboncoin - Masquer des annonces",
  "version": "1.0.12",
  "description": "Masquer les annonces indésirables sur leboncoin pour faciliter vos recherches récurrentes.",
  "author": "remy",
  "permissions": [
    "storage",
    "*://www.leboncoin.fr/*"
  ],
  "background": {
    "scripts": [
      "background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.leboncoin.fr/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Leboncoin - Masquer des annonces",
    "default_icon": {
      "32": "icons/icon-32.svg",
      "48": "icons/icon-48.svg",
      "64": "icons/icon-64.svg",
      "96": "icons/icon-96.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "icons": {
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "64": "icons/icon-64.svg",
    "96": "icons/icon-96.svg",
    "128": "icons/icon-128.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "leboncoin-hide-ads@remy",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "id": "leboncoin-hide-ads@remy",
      "strict_min_version": "142.0"
    }
  }
}
